{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Native",
            "type": "shell",
            "command": "make",
            "args": ["native"],
            "options": {
                "cwd": "${workspaceFolder}/01_SingleThreaded_CPU/Implementation"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Native Simulator",
            "type": "shell",
            "command": "make",
            "args": ["run"],
            "options": {
                "cwd": "${workspaceFolder}/01_SingleThreaded_CPU/Implementation"
            },
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "make",
            "args": ["clean"],
            "options": {
                "cwd": "${workspaceFolder}/01_SingleThreaded_CPU/Implementation"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
